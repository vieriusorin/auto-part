{
  "name": "@autocare/api-client",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./react": {
      "types": "./src/react/index.ts",
      "import": "./src/react/index.ts",
      "default": "./src/react/index.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "generate": "npm run openapi:generate -w @autocare/server && openapi-typescript ../../apps/server/openapi.json -o src/types.gen.ts",
    "generate:types": "openapi-typescript ../../apps/server/openapi.json -o src/types.gen.ts",
    "lint": "echo \"no lint configured\"",
    "test:vitest": "vitest run"
  },
  "peerDependencies": {
    "@tanstack/react-query": "^5.0.0",
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "@tanstack/react-query": { "optional": true },
    "react": { "optional": true }
  },
  "dependencies": {
    "openapi-fetch": "^0.13.0"
  },
  "devDependencies": {
    "@tanstack/react-query": "^5.64.0",
    "@types/react": "^19.2.0",
    "openapi-typescript": "^7.5.0",
    "react": "^19.2.0",
    "typescript": "~5.9.2",
    "vitest": "^4.1.4"
  }
}
