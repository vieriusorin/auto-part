{
  "name": "@autocare/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "biome check .",
    "test": "vitest run",
    "test:vitest": "vitest run",
    "test:coverage": "vitest run --coverage",
    "phase0:integrity-gate": "tsx scripts/phase0-integrity-gate.ts",
    "phase0:gate": "tsx scripts/phase0-gate.ts",
    "db:reset:phase0": "tsx scripts/db-reset-phase0.ts",
    "db:seed:phase0": "tsx scripts/db-seed-phase0.ts"
  },
  "dependencies": {
    "@autocare/auth": "0.1.0",
    "@autocare/db": "0.1.0",
    "@autocare/shared": "0.1.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.8.3",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "express-slow-down": "^3.1.0",
    "express-validator": "^7.3.2",
    "helmet": "^8.1.0",
    "inversify": "^8.1.0",
    "jose": "^6.2.2",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.6.0",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@vitest/coverage-v8": "^4.1.4",
    "drizzle-kit": "^0.30.6",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "~5.9.2",
    "vitest": "^4.1.4"
  }
}
