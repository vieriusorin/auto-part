{
  "name": "@autocare/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "echo \"no lint configured\"",
    "test:vitest": "vitest run",
    "test:coverage": "vitest run --coverage",
    "phase0:integrity-gate": "tsx scripts/phase0-integrity-gate.ts",
    "phase0:gate": "tsx scripts/phase0-gate.ts",
    "db:reset:phase0": "tsx scripts/db-reset-phase0.ts",
    "db:seed:phase0": "tsx scripts/db-seed-phase0.ts"
  },
  "dependencies": {
    "@autocare/auth": "0.1.0",
    "@autocare/db": "0.1.0",
    "@autocare/shared": "0.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.38.4",
    "express": "^4.21.1",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "pg": "^8.20.0",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.0",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.4",
    "supertest": "^7.2.2",
    "tsx": "^4.19.2",
    "typescript": "~5.9.2",
    "vitest": "^4.1.4"
  }
}
