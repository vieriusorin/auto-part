# apps/server — validated at startup by @autocare/config/server (fail-fast).
# Never commit a real .env; this file is the contract for required variables.

NODE_ENV=development
PORT=4000

# --- Database ---------------------------------------------------------------

# Postgres connection string.
DATABASE_URL=postgresql://autocare:autocare@localhost:5432/autocare

# --- HTTP / network perimeter ----------------------------------------------

# Comma-separated list of allowed browser origins (no wildcards).
# Leave unset to use the dev defaults (localhost:3000, localhost:3001).
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# trust proxy: number of hops, boolean, or named value. Must match your deploy topology
# (e.g. Azure App Service behind a Front Door is typically 2).
TRUST_PROXY=0

# Dev-only: auto-open Swagger UI on boot.
OPEN_API_DOCS=true

# Optional: force analytics writes to DB in non-production.
# ANALYTICS_STORAGE=db

# --- JWT access tokens ------------------------------------------------------

# Required in production when JWT_ACCESS_ALG is HS*. Minimum 32 chars.
# Generate with:  node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_ACCESS_SECRET=change-me-to-a-strong-dev-secret-at-least-32-chars

# Signing algorithm. HS256/384/512 use JWT_ACCESS_SECRET.
# RS256/384/512 use JWT_ACCESS_PRIVATE_KEY / JWT_ACCESS_PUBLIC_KEY (PEM).
JWT_ACCESS_ALG=HS256
# JWT_ACCESS_PRIVATE_KEY=
# JWT_ACCESS_PUBLIC_KEY=

# Access token lifetime in seconds (default 15m). Keep short.
JWT_ACCESS_TTL_SECONDS=900

# iss / aud claims. Rotate audience per environment if you cross-verify tokens elsewhere.
JWT_ISSUER=autocare-api
JWT_AUDIENCE=autocare

# --- Refresh tokens ---------------------------------------------------------

# Refresh TTL (max lifetime of a single refresh token).
REFRESH_TTL_DAYS=30

# Rotate the refresh token on every /auth/refresh call (recommended).
REFRESH_ROTATION=enabled

# Detect reuse of a revoked refresh token → revoke entire token family.
REFRESH_REUSE_DETECTION=enabled

# Session idle timeout: refresh fails if token unused for N days.
REFRESH_INACTIVITY_DAYS=7

# Absolute session cap: user must log in again after N days regardless of activity.
REFRESH_ABSOLUTE_MAX_DAYS=90

# Grace window (seconds) during which a just-rotated token still succeeds without
# triggering reuse detection (covers network retries). 0 disables.
REFRESH_GRACE_SECONDS=10

# --- Password policy & Argon2id --------------------------------------------

PASSWORD_MIN_LENGTH=12
PASSWORD_REQUIRE_MIXED_CASE=false
PASSWORD_REQUIRE_DIGIT=false
PASSWORD_REQUIRE_SYMBOL=false

# Argon2id cost parameters. Defaults roughly match OWASP 2024 guidance.
# Tune on target hardware so a single hash takes ~250-500ms.
ARGON2_TIME_COST=3
ARGON2_MEMORY_COST_KIB=65536
ARGON2_PARALLELISM=4

# --- Login protection -------------------------------------------------------

LOGIN_MAX_FAILED_ATTEMPTS=10
LOGIN_LOCKOUT_MINUTES=15

# --- Cookies (web client) ---------------------------------------------------

# Master switch: disable to force all clients to carry tokens in Authorization headers.
COOKIE_ENABLED=true

# Cookie domain. Leave unset for __Host- prefix (most secure; same-origin only).
# Set to e.g. ".autocare.app" only if you must share across subdomains.
# COOKIE_DOMAIN=

# SameSite policy. 'lax' is a good default; 'strict' is safest; 'none' requires secure=true.
COOKIE_SAMESITE=lax

# Leave unset: derived from NODE_ENV (false in development, true otherwise).
# COOKIE_SECURE=true

COOKIE_PATH=/

# Base cookie names. `__Host-` / `__Secure-` prefixes added automatically where eligible.
# COOKIE_ACCESS_NAME=autocare.access
# COOKIE_REFRESH_NAME=autocare.refresh

# --- CSRF (double-submit token; only relevant when cookies are used) --------

# Defaults to COOKIE_ENABLED when unset.
# CSRF_ENABLED=true

CSRF_COOKIE_NAME=autocare.csrf
CSRF_HEADER_NAME=x-csrf-token
CSRF_TOKEN_TTL_MINUTES=1440

# --- Social auth (Google OAuth) --------------------------------------------

# Disabled by default. Enable and set all values to allow /auth/social/google/*.
GOOGLE_OAUTH_ENABLED=false
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/auth/google/callback

# Invite emails
INVITE_LINK_BASE_URL=http://localhost:3000
INVITE_EMAIL_FROM=noreply@autocare.local
INVITE_DEFAULT_EXPIRES_DAYS=7
INVITE_RESEND_COOLDOWN_SECONDS=60
INVITE_RESEND_COOLDOWN_OWNER_SECONDS=45
INVITE_RESEND_COOLDOWN_ADMIN_SECONDS=60
