# apps/web — Next.js environment.
#
# NEXT_PUBLIC_* variables are inlined into the browser bundle at build time.
# Do NOT put secrets in NEXT_PUBLIC_* — use plain vars and read them only from
# server components / route handlers / server actions.

# Base URL the browser uses to reach the API (must be reachable from the client).
NEXT_PUBLIC_API_URL=http://localhost:4000

# Optional server-side override (SSR / server actions). Falls back to NEXT_PUBLIC_API_URL.
# API_URL=http://api.internal:4000
