{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/post-tsx-edit.sh"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(npm run build)",
      "Bash(npm run lint)",
      "Bash(npm run test *)",
      "Bash(node scripts/yg-preview.mjs *)",
      "Bash(npx playwright install *)",
      "Bash(npm install --save-dev playwright *)",
      "Bash(curl -s -o /dev/null -w * http://localhost:4200 *)",
      "Read(~/.zshrc)",
      "WebFetch(domain:localhost:4200)"
    ],
    "deny": [
      "Read(./.env*)",
      "Read(./.docker/secrets/**)",
      "Bash(docker run *)",
      "Read(./secrets/**)"
    ]
  },
  "companyAnnouncements": [
    "Welcome to Autocare!",
    "Reminder: Code reviews required for all PRs. Please ensure you have at least one reviewer before merging.",
    "New security policy in effect"
  ],
  "model": "claude-sonnet-4-6",
  "outputStyle": "verbose",
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": ["memory"],
  "sandbox": {
    "enabled": true,
    "network": {
      "allowedDomains": [
        "github.com",
        "npmjs.org",
        "registry.npmjs.org",
        "vercel.com",
        "localhost:4200"
      ]
    }
  },
  "showTurnDuration": true,
  "terminalProgressBarEnabled": true,
  "terminalProgressBarStyle": "bouncingBar",
  "terminalProgressBarColor": "blue"
}
