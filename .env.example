# =============================================================================
# Root .env.example — local development only
# =============================================================================
# In production / CI, inject variables via Azure Key Vault or pipeline variables
# rather than a .env file. This file documents the dev surface only.
#
# Each app also has its own .env.example:
#   - apps/server/.env.example   (server-only secrets)
#   - apps/web/.env.example      (Next.js; NEXT_PUBLIC_* is exposed to browser)
#   - apps/mobile/.env.example   (Expo; EXPO_PUBLIC_* is bundled into the app)
#
# Mobile bundles are reversible. NEVER put secrets in EXPO_PUBLIC_* vars.
# =============================================================================

NODE_ENV=development

# --- apps/server (read by @autocare/server at startup) ---------------------
PORT=4000
DATABASE_URL=postgresql://autocare:autocare@localhost:5432/autocare
# Comma-separated list of browser origins permitted by CORS.
# Mobile + server-to-server requests do not send an Origin and are unaffected.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
# trust proxy: number of hops, "true"/"false", or a named value (loopback, linklocal, uniquelocal).
# Set to the number of proxies in front of the API (e.g. 1 for Azure App Service).
TRUST_PROXY=0
# Auto-open Swagger UI when dev server boots. Set to false in CI.
OPEN_API_DOCS=true

# JWT access token settings (required for auth module startup).
JWT_ACCESS_SECRET=change-me-to-a-strong-dev-secret-at-least-32-chars
JWT_ACCESS_ALG=HS256
JWT_ACCESS_TTL_SECONDS=900
JWT_ISSUER=autocare-api
JWT_AUDIENCE=autocare

# Social auth (Google OAuth; optional)
GOOGLE_OAUTH_ENABLED=false
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/auth/google/callback

# Invite emails
INVITE_LINK_BASE_URL=http://localhost:3000
INVITE_EMAIL_FROM=noreply@autocare.local
INVITE_DEFAULT_EXPIRES_DAYS=7
INVITE_RESEND_COOLDOWN_SECONDS=60
INVITE_RESEND_COOLDOWN_OWNER_SECONDS=45
INVITE_RESEND_COOLDOWN_ADMIN_SECONDS=60
